<UserControl x:Class="Marketio_WPF.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Marketio_WPF.Converters"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header                -->
            <RowDefinition Height="Auto"/>
            <!-- Error / Success msgs   -->
            <RowDefinition Height="*"/>
            <!-- Main content split     -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             ROW 0 – Header
             ═══════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="⚙️ User Management"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#2C3E50"
                       VerticalAlignment="Center"/>
            <Button Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Margin="20,0,0,0" Padding="10,5"
                    Background="#3498DB" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════
             ROW 1 – Feedback messages
             ═══════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C" FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>
            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="#27AE60" FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding SuccessMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════
             ROW 2 – User list (left)  +  Action panel (right)
             ═══════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- DataGrid   -->
                <ColumnDefinition Width="260"/>
                <!-- Actions    -->
            </Grid.ColumnDefinitions>

            <!-- ─── User DataGrid ─────────────────────────── -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F9F9F9"
                          RowBackground="White"
                          BorderBrush="#BDC3C7"
                          BorderThickness="1">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Full Name"
                                            Binding="{Binding FullName}"
                                            Width="150"/>
                        <DataGridTextColumn Header="Email"
                                            Binding="{Binding Email}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Username"
                                            Binding="{Binding UserName}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Roles"
                                            Binding="{Binding Roles}"
                                            Width="100"/>
                        <DataGridCheckBoxColumn Header="Active"
                                                Binding="{Binding IsActive}"
                                                Width="55"/>
                        <DataGridCheckBoxColumn Header="Locked"
                                                Binding="{Binding IsLocked}"
                                                Width="55"/>
                        <DataGridTextColumn Header="Created"
                                            Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Last Login"
                                            Binding="{Binding LastLoginAt, StringFormat=\{0:dd/MM/yyyy\}}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading bar sits at top of the DataGrid row -->
                <ProgressBar Grid.Row="1"
                             IsIndeterminate="True" Height="4"
                             Visibility="{Binding IsBusy,
                                 Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <!-- ─── Action Panel ───────────────────────────── -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Selected user info card -->
                    <Border Background="#ECF0F1"
                            BorderBrush="#BDC3C7" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Selected user"
                                       FontSize="11" Foreground="#7F8C8D"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedUser.FullName, FallbackValue='— none —'}"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#2C3E50" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedUser.Email, FallbackValue=''}"
                                       FontSize="11" Foreground="#555"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedUser.Roles, StringFormat='Roles: {0}', FallbackValue=''}"
                                       FontSize="11" Foreground="#555"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── 1. Role Management ── -->
                    <Border Background="White"
                            BorderBrush="#BDC3C7" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🎭 Role Management"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                            <TextBlock Text="Select role" FontSize="11"
                                       Foreground="#7F8C8D" Margin="0,0,0,3"/>
                            <ComboBox ItemsSource="{Binding AvailableRoles}"
                                      SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                      Height="28" Margin="0,0,0,8"/>

                            <Button Content="✅ Assign Role"
                                    Command="{Binding AssignRoleCommand}"
                                    Padding="8,5" Margin="0,0,0,5"
                                    Background="#27AE60" Foreground="White"
                                    FontWeight="Bold" Cursor="Hand"
                                    BorderThickness="0" HorizontalAlignment="Stretch"/>

                            <Button Content="❌ Remove Role"
                                    Command="{Binding RemoveRoleCommand}"
                                    Padding="8,5"
                                    Background="#E67E22" Foreground="White"
                                    FontWeight="Bold" Cursor="Hand"
                                    BorderThickness="0" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- ── 2. Account Security ── -->
                    <Border Background="White"
                            BorderBrush="#BDC3C7" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🔒 Account Security"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                            <Button Content="🔑 Reset Password"
                                    Command="{Binding ResetPasswordCommand}"
                                    Padding="8,5" Margin="0,0,0,5"
                                    Background="#3498DB" Foreground="White"
                                    FontWeight="Bold" Cursor="Hand"
                                    BorderThickness="0" HorizontalAlignment="Stretch"/>

                            <Button Content="🔐 Lock Account"
                                    Command="{Binding LockUserCommand}"
                                    Padding="8,5"
                                    Background="#8E44AD" Foreground="White"
                                    FontWeight="Bold" Cursor="Hand"
                                    BorderThickness="0" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- ── 3. GDPR – User Deletion ── -->
                    <Border Background="#FDF2F2"
                            BorderBrush="#E74C3C" BorderThickness="1"
                            CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock Text="🗑️ User Deletion"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#C0392B" Margin="0,0,0,4"/>
                            <TextBlock Text="Permanently removes account (GDPR Right to be Forgotten)."
                                       FontSize="10" Foreground="#999"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <Button Content="🗑️ Delete User"
                                    Command="{Binding DeleteUserCommand}"
                                    Padding="8,5"
                                    Background="#E74C3C" Foreground="White"
                                    FontWeight="Bold" Cursor="Hand"
                                    BorderThickness="0" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
