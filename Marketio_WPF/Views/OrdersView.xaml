<UserControl x:Class="Marketio_WPF.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Marketio_WPF.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1100"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <converters:StringNullOrEmptyToVisibilityConverter
            x:Key="StringNullOrEmptyToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="📋 Orders"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       VerticalAlignment="Center"/>

            <Button Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Margin="20,0,0,0"
                    Padding="10,5"
                    Background="#3498DB"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>
        </StackPanel>

        <!-- Messages -->
        <StackPanel Grid.Row="1"
                    Margin="0,0,0,8">

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage,
                                            Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>

            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="#27AE60"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Visibility="{Binding SuccessMessage,
                                            Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Filter bar -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">

            <TextBlock Text="Filter op status:"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="StatusFilterBox"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding StatusFilter, Mode=TwoWay}"
                      Width="140"
                      Height="28"
                      Margin="0,0,8,0">

                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Processing"/>
                <ComboBoxItem Content="Shipped"/>
                <ComboBoxItem Content="Delivered"/>
                <ComboBoxItem Content="Cancelled"/>

            </ComboBox>

            <Button Content="▶ Filter"
                    Command="{Binding FilterByStatusCommand}"
                    Padding="10,4"
                    Background="#95A5A6"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>
        </StackPanel>

        <!-- Orders Grid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Orders}"
                  SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9F9F9"
                  RowBackground="White"
                  BorderBrush="#BDC3C7"
                  BorderThickness="1">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="45"/>

                <DataGridTextColumn Header="Order #"
                                    Binding="{Binding OrderNumber}"
                                    Width="130"/>

                <DataGridTextColumn Header="Klant-ID"
                                    Binding="{Binding CustomerId}"
                                    Width="160"/>

                <DataGridTextColumn Header="Datum"
                                    Binding="{Binding OrderDate,
                                                      StringFormat={}{0:dd/MM/yyyy}}"
                                    Width="90"/>

                <DataGridTextColumn Header="Status"
                                    Binding="{Binding StatusName}"
                                    Width="95"/>

                <DataGridTextColumn Header="Betaling"
                                    Binding="{Binding PaymentMethodName}"
                                    Width="105"/>

                <DataGridTextColumn Header="Totaal"
                                    Binding="{Binding TotalAmount,
                                                      StringFormat=€{0:N2}}"
                                    Width="80"/>

                <DataGridCheckBoxColumn Header="Actief"
                                        Binding="{Binding IsActive}"
                                        Width="55"/>

                <DataGridTextColumn Header="Verzendadres"
                                    Binding="{Binding ShippingAddress}"
                                    Width="*"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom toolbar -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right">

            <Button Content="✏️ Update Status"
                    Command="{Binding UpdateOrderCommand}"
                    Padding="10,5"
                    Margin="0,0,5,0"
                    Background="#F39C12"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>

            <Button Content="🗑️ Delete"
                    Command="{Binding DeleteOrderCommand}"
                    Padding="10,5"
                    Background="#E74C3C"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>

        </StackPanel>

        <!-- Loading -->
        <ProgressBar Grid.Row="3"
                     Height="4"
                     VerticalAlignment="Top"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy,
                                          Converter={StaticResource BoolToVisibilityConverter}}"/>

    </Grid>
</UserControl>