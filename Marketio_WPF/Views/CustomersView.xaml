<UserControl x:Class="Marketio_WPF.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="👥 Customers"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#2C3E50" VerticalAlignment="Center"/>
            <Button Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Margin="20,0,5,0" Padding="10,5"
                    Background="#3498DB" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
            <Button Content="➕ New Customer"
                    Command="{Binding CreateCustomerCommand}"
                    Padding="10,5"
                    Background="#27AE60" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>

        <!-- Messages -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C" FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>
            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="#27AE60" FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding SuccessMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Search bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Width="260" Height="28" Padding="6,4"
                     BorderBrush="#BDC3C7" BorderThickness="1"
                     Margin="0,0,8,0"/>
            <Button Content="🔍 Zoek"
                    Command="{Binding SearchCommand}"
                    Padding="10,4"
                    Background="#95A5A6" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Customers}"
                  SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9F9F9"
                  RowBackground="White"
                  BorderBrush="#BDC3C7"
                  BorderThickness="1">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Voornaam"
                                    Binding="{Binding FirstName}"
                                    Width="120"/>
                <DataGridTextColumn Header="Achternaam"
                                    Binding="{Binding LastName}"
                                    Width="120"/>
                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="210"/>
                <DataGridTextColumn Header="Telefoon"
                                    Binding="{Binding PhoneNumber}"
                                    Width="120"/>
                <DataGridTextColumn Header="Aangemaakt"
                                    Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}"
                                    Width="100"/>
                <DataGridCheckBoxColumn Header="Actief"
                                        Binding="{Binding IsActive}"
                                        Width="55"/>
                <DataGridTextColumn Header="Adres"
                                    Binding="{Binding Address}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom toolbar -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    Margin="0,10,0,0" HorizontalAlignment="Right">
            <Button Content="✏️ Edit"
                    Command="{Binding EditCustomerCommand}"
                    Padding="10,5" Margin="0,0,5,0"
                    Background="#F39C12" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
            <Button Content="🗑️ Delete"
                    Command="{Binding DeleteCustomerCommand}"
                    Padding="10,5"
                    Background="#E74C3C" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>

        <!-- Loading overlay -->
        <ProgressBar Grid.Row="3"
                     IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsBusy,
                         Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</UserControl>