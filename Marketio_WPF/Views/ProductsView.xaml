<UserControl x:Class="Marketio_WPF.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="UserControl_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="📦 Products"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#2C3E50"
                       VerticalAlignment="Center"/>
            <Button Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Margin="20,0,5,0" Padding="10,5"
                    Background="#3498DB" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
            <Button Content="➕ New Product"
                    Command="{Binding CreateProductCommand}"
                    Padding="10,5"
                    Background="#27AE60" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>

        <!-- Messages -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C" FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>
            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="#27AE60" FontSize="12" TextWrapping="Wrap"
                       Visibility="{Binding SuccessMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9F9F9"
                  RowBackground="White"
                  BorderBrush="#BDC3C7"
                  BorderThickness="1">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"     Binding="{Binding Id}"    Width="50"/>
                <DataGridTextColumn Header="Name"   Binding="{Binding Name}"  Width="180"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="Price"
                                    Binding="{Binding Price, StringFormat=€\{0:N2\}}"
                                    Width="90"/>
                <DataGridTextColumn Header="Stock"  Binding="{Binding Stock}" Width="70"/>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom toolbar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    Margin="0,10,0,0" HorizontalAlignment="Right">
            <Button Content="✏️ Edit"
                    Command="{Binding EditProductCommand}"
                    Padding="10,5" Margin="0,0,5,0"
                    Background="#F39C12" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
            <Button Content="🗑️ Delete"
                    Command="{Binding DeleteProductCommand}"
                    Padding="10,5"
                    Background="#E74C3C" Foreground="White"
                    FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>

        <!-- Loading overlay -->
        <ProgressBar Grid.Row="2"
                     IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsBusy,
                         Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</UserControl>