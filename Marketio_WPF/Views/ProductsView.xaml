<UserControl x:Class="Marketio_WPF.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Marketio_WPF.Converters"
             xmlns:controls="clr-namespace:Marketio_WPF.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1100"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringNullOrEmptyToVisibilityConverter
            x:Key="StringNullOrEmptyToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Filter balk -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Meldingen -->
            <RowDefinition Height="*"/>
            <!-- Row 3: DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Toolbar -->
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="📦 Products"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       VerticalAlignment="Center"/>

            <Button Content="🔄 Refresh"
                    Command="{Binding LoadProductsCommand}"
                    Margin="20,0,0,0"
                    Padding="10,5"
                    Background="#3498DB"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>

        </StackPanel>

        <!-- Row 1: Categorie-filter -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,8"
                    VerticalAlignment="Center">

            <TextBlock Text="Categorie:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"/>

            <ComboBox Width="170"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding CategoryFilterOptions}"
                      SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}"/>

        </StackPanel>

        <!-- Row 2: Meldingen -->
        <StackPanel Grid.Row="2"
                    Margin="0,0,0,8">

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage,
                                            Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>

            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="#27AE60"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Visibility="{Binding SuccessMessage,
                                            Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>

        </StackPanel>

        <!-- Row 3: Products DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9F9F9"
                  RowBackground="White"
                  BorderBrush="#BDC3C7"
                  BorderThickness="1">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="45"/>

                <DataGridTextColumn Header="Naam"
                                    Binding="{Binding Name}"
                                    Width="200"/>

                <DataGridTextColumn Header="Beschrijving"
                                    Binding="{Binding Description}"
                                    Width="*"/>

                <DataGridTextColumn Header="Prijs"
                                    Binding="{Binding Price, StringFormat=€{0:N2}}"
                                    Width="80"/>

                <DataGridTemplateColumn Header="Voorraad" Width="110" SortMemberPath="Stock">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <controls:StockIndicator Stock="{Binding Stock}"
                                                     LowThreshold="5"
                                                     MediumThreshold="20"
                                                     Margin="2,1"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- {Binding CategoryName} — Product heeft geen CategoryName property;
                     Category is een ProductCategory enum, ToString() geeft de naam. -->
                <DataGridTextColumn Header="Categorie"
                                    Binding="{Binding Category}"
                                    Width="110"/>

                <DataGridCheckBoxColumn Header="Actief"
                                        Binding="{Binding IsActive}"
                                        Width="55"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- Row 4: Toolbar -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right">

            <Button Content="➕ Nieuw"
                    Command="{Binding CreateProductCommand}"
                    Padding="10,5"
                    Margin="0,0,5,0"
                    Background="#27AE60"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>

            <Button Content="✏️ Bewerken"
                    Command="{Binding EditProductCommand}"
                    Padding="10,5"
                    Margin="0,0,5,0"
                    Background="#F39C12"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>

            <Button Content="🗑️ Delete"
                    Command="{Binding DeleteProductCommand}"
                    Padding="10,5"
                    Background="#E74C3C"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"/>

        </StackPanel>

        <!-- Loading indicator (Row 3, boven de DataGrid) -->
        <ProgressBar Grid.Row="3"
                     Height="4"
                     VerticalAlignment="Top"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy,
                                          Converter={StaticResource BoolToVisibilityConverter}}"/>

    </Grid>

</UserControl>
