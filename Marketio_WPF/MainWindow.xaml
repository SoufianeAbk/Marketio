<Window x:Class="Marketio_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Marketio_WPF"
        xmlns:views="clr-namespace:Marketio_WPF.Views"
        mc:Ignorable="d"
        Title="Marketio - Administration"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Stijl voor navigatie-menuitems in de zijbalk -->
        <Style x:Key="NavMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F618D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stijl voor de separator in het menu -->
        <Style x:Key="NavSeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="221*"/>
            <ColumnDefinition Width="979*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bovenste header/toolbar -->
        <Border Grid.Row="0"
                Background="#2C3E50"
                Padding="20,10,20,10" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="📊 Marketio Administration"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <Border Width="1" Background="#555555" Margin="10,10,10,10"/>

                <TextBlock Text="{Binding CurrentUserName, StringFormat='User: {0}'}"
                           FontSize="12"
                           Foreground="#CCCCCC"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                <StackPanel HorizontalAlignment="Stretch"/>

                <Button Content="🚪 Logout"
                        Command="{Binding LogoutCommand}"
                        Width="100"
                        Height="40"
                        Background="#E74C3C"
                        Foreground="White"
                        FontWeight="Bold"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Hoofdinhoud met navigatie -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Linker navigatiemenu (Menu-element met verticale oriëntatie) -->
            <Border Grid.Column="0" Background="#34495E">
                <Menu Background="Transparent"
                      BorderThickness="0"
                      IsMainMenu="False"
                      VerticalAlignment="Top">
                    <Menu.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" Margin="0,10,0,0"/>
                        </ItemsPanelTemplate>
                    </Menu.ItemsPanel>

                    <MenuItem Header="📦 Products"
                              Command="{Binding NavigateToProductsCommand}"
                              Style="{StaticResource NavMenuItemStyle}"/>

                    <MenuItem Header="📋 Orders"
                              Command="{Binding NavigateToOrdersCommand}"
                              Style="{StaticResource NavMenuItemStyle}"/>

                    <MenuItem Header="👥 Customers"
                              Command="{Binding NavigateToCustomersCommand}"
                              Style="{StaticResource NavMenuItemStyle}"
                              Visibility="{Binding IsEmployee, Converter={StaticResource BoolToVis}}"/>

                    <MenuItem Header="⚙️ Admin"
                              Command="{Binding NavigateToAdminCommand}"
                              Style="{StaticResource NavMenuItemStyle}"
                              Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>

                    <Separator Style="{StaticResource NavSeparatorStyle}"/>

                    <MenuItem Header="➕ Register User"
                              Command="{Binding NavigateToRegisterCommand}"
                              Style="{StaticResource NavMenuItemStyle}"
                              Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                </Menu>
            </Border>

            <!-- Rechter inhoudsgebied -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentView}"
                            Margin="20"/>
        </Grid>
    </Grid>
</Window>
