@page
@using Marketio_Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@model RegisterModel
@{
    ViewData["Title"] = Localizer["Register_Title"];
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">
                        <i class="bi bi-person-plus"></i> @Localizer["Register_CreateNewAccount"]
                    </h2>
                </div>
                <div class="card-body">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Input.FirstName" class="form-label">@Localizer["Register_FirstName"]</label>
                                <input asp-for="Input.FirstName" class="form-control" placeholder="@Localizer["Register_FirstNamePlaceholder"]" autocomplete="given-name" />
                                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.LastName" class="form-label">@Localizer["Register_LastName"]</label>
                                <input asp-for="Input.LastName" class="form-control" placeholder="@Localizer["Register_LastNamePlaceholder"]" autocomplete="family-name" />
                                <span asp-validation-for="Input.LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">@Localizer["Register_Email"]</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="@Localizer["Register_EmailPlaceholder"]" autocomplete="email" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Address" class="form-label">@Localizer["Register_Address"]</label>
                            <input asp-for="Input.Address" class="form-control" placeholder="@Localizer["Register_AddressPlaceholder"]" autocomplete="street-address" />
                            <span asp-validation-for="Input.Address" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">@Localizer["Register_Password"]</label>
                            <input asp-for="Input.Password" class="form-control" placeholder="@Localizer["Register_PasswordPlaceholder"]" autocomplete="new-password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ConfirmPassword" class="form-label">@Localizer["Register_ConfirmPassword"]</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="@Localizer["Register_ConfirmPassword"]" autocomplete="new-password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <hr class="my-4" />

                        <div class="mb-2">
                            <div class="form-check">
                                <input asp-for="Input.TermsConsentGiven" class="form-check-input" />
                                <label asp-for="Input.TermsConsentGiven" class="form-check-label">
                                    Ik accepteer de <a asp-controller="Home" asp-action="Terms" target="_blank">algemene voorwaarden</a>
                                </label>
                                <span asp-validation-for="Input.TermsConsentGiven" class="text-danger d-block"></span>
                            </div>
                        </div>

                        <div class="mb-2">
                            <div class="form-check">
                                <input asp-for="Input.PrivacyConsentGiven" class="form-check-input" />
                                <label asp-for="Input.PrivacyConsentGiven" class="form-check-label">
                                    Ik accepteer het <a asp-controller="Privacy" asp-action="MyPrivacy" target="_blank">privacybeleid</a>
                                </label>
                                <span asp-validation-for="Input.PrivacyConsentGiven" class="text-danger d-block"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input asp-for="Input.MarketingOptIn" class="form-check-input" />
                                <label asp-for="Input.MarketingOptIn" class="form-check-label">
                                    Ik wil graag aanbiedingen en nieuws ontvangen
                                </label>
                            </div>
                        </div>

                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-check"></i> @Localizer["Register_SubmitButton"]
                        </button>

                        <hr class="my-4" />

                        <p class="text-center mb-0">
                            @Localizer["Register_AlreadyHaveAccount"]
                            <a asp-page="./Login">@Localizer["Register_LoginHere"]</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
