@page
@using Marketio_Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@model RegisterModel
@{
    ViewData["Title"] = Localizer["Register_Title"];
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">
                        <i class="bi bi-person-plus"></i> @Localizer["Register_CreateNewAccount"]
                    </h2>
                </div>
                <div class="card-body">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.FirstName" class="form-label">@Localizer["Register_FirstName"]</label>
                            <input asp-for="Input.FirstName" class="form-control" autocomplete="given-name" aria-required="true" placeholder="@Localizer["Register_FirstNamePlaceholder"]" />
                            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.LastName" class="form-label">@Localizer["Register_LastName"]</label>
                            <input asp-for="Input.LastName" class="form-control" autocomplete="family-name" aria-required="true" placeholder="@Localizer["Register_LastNamePlaceholder"]" />
                            <span asp-validation-for="Input.LastName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">@Localizer["Register_Email"]</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="@Localizer["Register_EmailPlaceholder"]" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Address" class="form-label">@Localizer["Register_Address"]</label>
                            <textarea asp-for="Input.Address" class="form-control" rows="2" placeholder="@Localizer["Register_AddressPlaceholder"]"></textarea>
                            <span asp-validation-for="Input.Address" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">@Localizer["Register_Password"]</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="@Localizer["Register_PasswordPlaceholder"]" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ConfirmPassword" class="form-label">@Localizer["Register_ConfirmPassword"]</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <!-- GDPR Consent: Terms of Service -->
                        <div class="mb-3 form-check">
                            <input asp-for="Input.TermsConsentGiven" class="form-check-input" aria-required="true" />
                            <label asp-for="Input.TermsConsentGiven" class="form-check-label">
                                @Localizer["Register_IAccept"]
                                <a asp-controller="Home" asp-action="Terms" target="_blank" class="text-primary fw-bold">@Localizer["Register_TermsOfService"]</a>
                            </label>
                            <span asp-validation-for="Input.TermsConsentGiven" class="d-block text-danger mt-1"></span>
                        </div>

                        <!-- GDPR Consent: Privacy Policy -->
                        <div class="mb-3 form-check">
                            <input asp-for="Input.PrivacyConsentGiven" class="form-check-input" aria-required="true" />
                            <label asp-for="Input.PrivacyConsentGiven" class="form-check-label">
                                @Localizer["Register_IAccept"]
                                <a asp-controller="Home" asp-action="Privacy" target="_blank" class="text-primary fw-bold">@Localizer["Register_PrivacyPolicy"]</a>
                            </label>
                            <span asp-validation-for="Input.PrivacyConsentGiven" class="d-block text-danger mt-1"></span>
                        </div>

                        <!-- Marketing Opt-in -->
                        <div class="mb-3 form-check">
                            <input asp-for="Input.MarketingOptIn" class="form-check-input" />
                            <label asp-for="Input.MarketingOptIn" class="form-check-label">
                                @Localizer["Register_ReceiveOffersAndNews"]
                            </label>
                        </div>

                        <!-- GDPR Information Box -->
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-shield-check"></i>
                            <strong>@Localizer["GDPR_Title"]:</strong>
                            @Localizer["GDPR_Description"]
                        </div>

                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-check"></i> @Localizer["Register_SubmitButton"]
                        </button>

                        <div class="mt-3 text-center">
                            <p>
                                @Localizer["Register_AlreadyHaveAccount"] <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["Register_LoginHere"]</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}