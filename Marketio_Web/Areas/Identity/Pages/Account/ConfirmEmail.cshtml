@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "E-mail bevestigen";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card shadow">
                @if (Model.StatusMessage.StartsWith("Bedankt"))
                {
                    <div class="card-header bg-success text-white">
                        <h2 class="mb-0">
                            <i class="bi bi-check-circle"></i> E-mail bevestigd
                        </h2>
                    </div>
                    <div class="card-body text-center">
                        <div class="mb-4">
                            <i class="bi bi-envelope-check" style="font-size: 4rem; color: #198754;"></i>
                        </div>
                        <p class="lead">@Model.StatusMessage</p>
                        <a asp-page="./Login" class="btn btn-primary mt-3">
                            <i class="bi bi-box-arrow-in-right"></i> Inloggen
                        </a>
                    </div>
                }
                else
                {
                    <div class="card-header bg-danger text-white">
                        <h2 class="mb-0">
                            <i class="bi bi-x-circle"></i> Bevestiging mislukt
                        </h2>
                    </div>
                    <div class="card-body text-center">
                        <div class="mb-4">
                            <i class="bi bi-envelope-x" style="font-size: 4rem; color: #dc3545;"></i>
                        </div>
                        <p class="lead">@Model.StatusMessage</p>
                        <a asp-page="./Register" class="btn btn-secondary mt-3">
                            <i class="bi bi-person-plus"></i> Opnieuw registreren
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
