@page
@using Marketio_Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@model RegisterConfirmationModel
@{
    ViewData["Title"] = Localizer["RegisterConfirmation_Title"];
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h2 class="mb-0">
                        <i class="bi bi-check-circle"></i> @Localizer["RegisterConfirmation_Success"]
                    </h2>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-envelope-check" style="font-size: 4rem; color: #198754;"></i>
                    </div>
                    <h4 class="mb-3">@Localizer["RegisterConfirmation_ConfirmEmail"]</h4>
                    <p class="lead">
                        @Localizer["RegisterConfirmation_EmailSentTo"] <strong>@Model.Email</strong>
                    </p>
                    <p>
                        @Localizer["RegisterConfirmation_CheckInbox"]
                    </p>
                    <hr class="my-4">
                    <p class="text-muted">
                        <i class="bi bi-info-circle"></i>
                        @Localizer["RegisterConfirmation_CloseWindow"]
                    </p>
                    <a asp-page="./Login" class="btn btn-primary mt-3">
                        <i class="bi bi-box-arrow-in-right"></i> @Localizer["RegisterConfirmation_GoToLogin"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>