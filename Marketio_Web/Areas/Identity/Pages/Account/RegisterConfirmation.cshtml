@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Registratie bevestiging";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h2 class="mb-0">
                        <i class="bi bi-check-circle"></i> Registratie Succesvol
                    </h2>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-envelope-check" style="font-size: 4rem; color: #198754;"></i>
                    </div>
                    <h4 class="mb-3">Bevestig uw email adres</h4>
                    <p class="lead">
                        Er is een bevestigingsmail verzonden naar <strong>@Model.Email</strong>
                    </p>
                    <p>
                        Klik op de link in de email om uw account te activeren.
                        Controleer ook uw spam folder als u de email niet binnen enkele minuten ontvangt.
                    </p>
                    <hr class="my-4">
                    <p class="text-muted">
                        <i class="bi bi-info-circle"></i>
                        U kunt dit venster sluiten en inloggen zodra u uw email heeft bevestigd.
                    </p>
                    <a asp-page="./Login" class="btn btn-primary mt-3">
                        <i class="bi bi-box-arrow-in-right"></i> Naar Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>