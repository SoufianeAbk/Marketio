@{
    ViewData["Title"] = "Beheer Rollen";
    var user = ViewBag.User as Marketio_Web.Models.ApplicationUser;
    var userRoles = ViewBag.UserRoles as IList<string>;
    var allRoles = ViewBag.AllRoles as List<string>;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5">
                <i class="bi bi-shield-check"></i> Beheer Rollen
            </h1>
            <p class="lead text-muted">Gebruiker: <strong>@user.FullName (@user.Email)</strong></p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Terug naar Overzicht
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill"></i> @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Huidige Roll -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-check"></i> Huidige Rollen
                    </h5>
                </div>
                <div class="card-body">
                    @if (userRoles != null && userRoles.Any())
                    {
                        <ul class="list-group">
                            @foreach (var role in userRoles)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>
                                        @if (role == "Admin")
                                        {
                                            <i class="bi bi-shield-fill-check text-danger"></i>
                                        }
                                        else if (role == "Manager")
                                        {
                                            <i class="bi bi-person-badge text-warning"></i>
                                        }
                                        else if (role == "Customer")
                                        {
                                            <i class="bi bi-person text-info"></i>
                                        }
                                        <strong>@role</strong>
                                    </span>
                                    <form asp-action="RemoveRole" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="role" value="@role" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Weet u zeker dat u de rol \'@role\' wilt verwijderen?')">
                                            <i class="bi bi-trash"></i> Verwijder
                                        </button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0" role="alert">
                            <i class="bi bi-info-circle"></i> Deze gebruiker heeft nog geen rollen toegewezen.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Assign Nieuwe Roll -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle"></i> Rol Toewijzen
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="AssignRole" method="post">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <div class="mb-3">
                            <label for="role" class="form-label">Selecteer een rol</label>
                            <select name="role" id="role" class="form-select" required>
                                <option value="" disabled selected>-- Kies een rol --</option>
                                @if (allRoles != null)
                                {
                                    @foreach (var role in allRoles)
                                    {
                                        var isAssigned = userRoles?.Contains(role) ?? false;
                                        <option value="@role" disabled="@isAssigned">
                                            @role @(isAssigned ? "(al toegewezen)" : "")
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <div class="alert alert-light border" role="alert">
                                <h6 class="alert-heading">
                                    <i class="bi bi-info-circle"></i> Rol Beschrijvingen:
                                </h6>
                                <ul class="mb-0 small">
                                    <li><strong>Admin:</strong> Volledige toegang tot alle functies inclusief gebruikersbeheer</li>
                                    <li><strong>Manager:</strong> Beheer van producten, bestellingen en rapporten</li>
                                    <li><strong>Customer:</strong> Standaard gebruiker met toegang tot winkel en bestellingen</li>
                                </ul>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-check-circle"></i> Rol Toewijzen
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- User Information Cart -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-circle"></i> Gebruikersinformatie
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Naam:</strong> @user.FullName</p>
                            <p><strong>Email:</strong> @user.Email</p>
                            <p>
                                <strong>Email Bevestigd:</strong>
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge bg-success">Ja</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Nee</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Adres:</strong> @(string.IsNullOrEmpty(user.Address) ? "Niet opgegeven" : user.Address)</p>
                            <p><strong>Telefoon:</strong> @(string.IsNullOrEmpty(user.PhoneNumber) ? "Niet opgegeven" : user.PhoneNumber)</p>
                            <p>
                                <strong>Account Status:</strong>
                                @if (user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow)
                                {
                                    <span class="badge bg-danger">Geblokkeerd tot @user.LockoutEnd.Value.ToString("dd-MM-yyyy HH:mm")</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Actief</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts na 5 seconden
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}