@using Marketio_Web.Services
@model IEnumerable<GdprAuditLogDto>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = "GDPR Auditlogboeken";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">
                <i class="bi bi-shield-check"></i> GDPR Auditlogboeken
            </h1>
            <p class="lead text-muted">Bekijk alle GDPR-gerelateerde activiteiten en toestemmingsgebeurtenissen</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("ExportAuditLogs", new { startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, eventType = ViewBag.EventType })"
               class="btn btn-outline-success">
                <i class="bi bi-download"></i> Export CSV
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Form -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-funnel"></i> Filters
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="AuditLogs" method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Startdatum</label>
                    <input type="date"
                           class="form-control"
                           id="startDate"
                           name="startDate"
                           value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3">
                    <label for="endDate" class="form-label">Einddatum</label>
                    <input type="date"
                           class="form-control"
                           id="endDate"
                           name="endDate"
                           value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3">
                    <label for="eventType" class="form-label">Gebeurtenistype</label>
                    <select class="form-select" id="eventType" name="eventType">
                        <option value="">-- Alles --</option>
                        @foreach (var eventType in ViewBag.EventTypes ?? new string[] { })
                        {
                            <option value="@eventType" selected="@(ViewBag.EventType == eventType)">
                                @eventType
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Filteren
                        </button>
                        <a asp-action="AuditLogs" class="btn btn-secondary">
                            <i class="bi bi-arrow-clockwise"></i> Resetten
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Audit Logs Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">
                <i class="bi bi-list-ul"></i> Alle Logboeken
                <span class="badge bg-light text-dark ms-2">@ViewBag.TotalCount totaal</span>
            </h5>
        </div>

        @if (!Model.Any())
        {
            <div class="card-body">
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle"></i> Geen logboeken gevonden met de geselecteerde filters.
                </div>
            </div>
        }
        else
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>
                                    <i class="bi bi-calendar"></i> Timestamp
                                </th>
                                <th>
                                    <i class="bi bi-person"></i> UserID
                                </th>
                                <th>
                                    <i class="bi bi-event"></i> Ereignis
                                </th>
                                <th>
                                    <i class="bi bi-check-square"></i> Toestemmingstype
                                </th>
                                <th>
                                    <i class="bi bi-shield"></i> Status
                                </th>
                                <th>
                                    <i class="bi bi-globe"></i> IP-adres
                                </th>
                                <th>
                                    <i class="bi bi-gear"></i> Verwerkt
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td>
                                        <small>@log.Timestamp.ToString("dd-MM-yyyy HH:mm:ss")</small>
                                    </td>
                                    <td>
                                        <code class="text-muted">@log.UserId.Substring(0, Math.Min(8, log.UserId.Length))...</code>
                                    </td>
                                    <td>
                                        @if (log.EventType == "ConsentGiven")
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> @log.EventType
                                            </span>
                                        }
                                        else if (log.EventType == "ConsentWithdrawn")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-exclamation-circle"></i> @log.EventType
                                            </span>
                                        }
                                        else if (log.EventType == "DeletionRequested")
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-exclamation-triangle"></i> @log.EventType
                                            </span>
                                        }
                                        else if (log.EventType == "DataExported")
                                        {
                                            <span class="badge bg-info">
                                                <i class="bi bi-download"></i> @log.EventType
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@log.EventType</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark">@log.ConsentType</span>
                                    </td>
                                    <td>
                                        @if (log.Granted)
                                        {
                                            <span class="badge bg-success">Geaccepteerd</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Geweigerd</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">@(log.IpAddress ?? "N/A")</small>
                                    </td>
                                    <td>
                                        @if (log.ProcessedDate.HasValue)
                                        {
                                            <small class="text-muted">@log.ProcessedDate.Value.ToString("dd-MM-yyyy HH:mm")</small>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark">Ausstehend</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            <div class="card-footer">
                <nav aria-label="Page navigation">
                    <ul class="pagination mb-0">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   href="@Url.Action("AuditLogs", new { page = 1, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, eventType = ViewBag.EventType })">
                                    &laquo; Eerste
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   href="@Url.Action("AuditLogs", new { page = ViewBag.CurrentPage - 1, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, eventType = ViewBag.EventType })">
                                    Vorige
                                </a>
                            </li>
                        }

                        @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   href="@Url.Action("AuditLogs", new { page = i, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, eventType = ViewBag.EventType })">
                                    @i
                                </a>
                            </li>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   href="@Url.Action("AuditLogs", new { page = ViewBag.CurrentPage + 1, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, eventType = ViewBag.EventType })">
                                    Volgende
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   href="@Url.Action("AuditLogs", new { page = ViewBag.TotalPages, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, eventType = ViewBag.EventType })">
                                    Laatste &raquo;
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function () {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => alert.remove(), 5000);
            });
        }, 100);
    </script>
}