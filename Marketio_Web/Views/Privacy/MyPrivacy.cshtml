@model Marketio_Web.Models.ApplicationUser
@using Marketio_Web.Services
@using Marketio_Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = "Mijn Privacy";
    var auditLogs = ViewBag.AuditLogs as IEnumerable<GdprAuditLogDto> ?? Enumerable.Empty<GdprAuditLogDto>();
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5">
                <i class="bi bi-shield-lock text-primary"></i> Mijn Privacy
            </h1>
            <p class="text-muted">
                Beheer uw toestemmingen, download uw gegevens of verwijder uw account — uw rechten onder de AVG.
            </p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle-fill"></i> @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- ==========================================
             KAART 1: Toestemmingen
        =========================================== -->
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-check2-square"></i> Mijn Toestemmingen
                    </h5>
                </div>
                <div class="card-body">

                    <!-- Verplichte toestemmingen (readonly) -->
                    <h6 class="text-muted mb-3">Verplichte toestemmingen</h6>

                    <div class="d-flex align-items-center justify-content-between mb-3 p-3 bg-light rounded">
                        <div>
                            <strong><i class="bi bi-file-earmark-text"></i> Algemene voorwaarden</strong>
                            <p class="small text-muted mb-0">Vereist voor gebruik van het platform</p>
                        </div>
                        @if (Model.TermsConsentGiven)
                        {
                            <span class="badge bg-success fs-6">
                                <i class="bi bi-check-circle-fill"></i> Geaccepteerd
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">
                                <i class="bi bi-x-circle-fill"></i> Niet geaccepteerd
                            </span>
                        }
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-4 p-3 bg-light rounded">
                        <div>
                            <strong><i class="bi bi-shield-check"></i> Privacybeleid</strong>
                            <p class="small text-muted mb-0">Vereist voor gebruik van het platform</p>
                        </div>
                        @if (Model.PrivacyConsentGiven)
                        {
                            <span class="badge bg-success fs-6">
                                <i class="bi bi-check-circle-fill"></i> Geaccepteerd
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">
                                <i class="bi bi-x-circle-fill"></i> Niet geaccepteerd
                            </span>
                        }
                    </div>

                    <hr />

                    <!-- Marketing toestemming (wijzigbaar) -->
                    <h6 class="text-muted mb-3">Optionele toestemmingen</h6>

                    <form asp-controller="Privacy" asp-action="UpdateConsent" method="post">
                        @Html.AntiForgeryToken()
                        <div class="p-3 border rounded mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input"
                                       type="checkbox"
                                       role="switch"
                                       id="marketingOptIn"
                                       name="marketingOptIn"
                                       value="true"
                                       @(Model.MarketingOptIn ? "checked" : "") />
                                <label class="form-check-label fw-bold" for="marketingOptIn">
                                    <i class="bi bi-envelope-heart"></i> Marketing e-mails
                                </label>
                            </div>
                            <p class="small text-muted mt-1 mb-0">
                                Ontvang aanbiedingen, nieuws en productUpdates van Marketio.
                                U kunt zich op elk moment uitschrijven.
                            </p>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-floppy"></i> Toestemmingen opslaan
                        </button>
                    </form>

                    @if (Model.ConsentGivenDate != default)
                    {
                        <p class="small text-muted mt-3 mb-0">
                            <i class="bi bi-clock"></i>
                            Toestemming gegeven op @Model.ConsentGivenDate.ToString("dd-MM-yyyy 'om' HH:mm") UTC
                        </p>
                    }
                </div>
            </div>
        </div>

        <!-- ==========================================
             KAART 2: Gegevens & Account
        =========================================== -->
        <div class="col-lg-6">

            <!-- Gegevens exporteren -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-download"></i> Mijn Gegevens Exporteren
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">
                        Download een volledig overzicht van uw persoonsgegevens, bestellingen en toestemmingsgeschiedenis
                        als JSON-bestand. Dit is uw recht op gegevensoverdraagbaarheid (AVG art. 20).
                    </p>
                    <ul class="small text-muted mb-3">
                        <li>Persoonlijke gegevens (naam, e-mail, adres)</li>
                        <li>Bestelgeschiedenis</li>
                        <li>Toestemmingslogboek</li>
                    </ul>
                    <form asp-controller="Privacy" asp-action="ExportData" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-info w-100 text-white">
                            <i class="bi bi-file-earmark-arrow-down"></i> Download mijn gegevens (JSON)
                        </button>
                    </form>
                </div>
            </div>

            <!-- Account verwijderen -->
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-x-fill"></i> Account Verwijderen
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.IsDeletionRequested)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-hourglass-split"></i>
                            <strong>Verwijderingsaanvraag in behandeling.</strong>
                            <p class="mb-0 small mt-1">
                                Uw aanvraag van @(Model.DeletionRequestedDate?.ToString("dd-MM-yyyy") ?? "onbekend")
                                wordt verwerkt. Uw account wordt binnen 30 dagen verwijderd.
                            </p>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small">
                            U heeft het recht om uw account en alle bijbehorende persoonsgegevens te laten verwijderen
                            (AVG art. 17 — Recht op vergetelheid). Uw bestelgeschiedenis wordt geanonimiseerd
                            voor boekhoudkundige doeleinden.
                        </p>
                        <div class="alert alert-warning small mb-3">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <strong>Let op:</strong> Deze actie kan niet ongedaan worden gemaakt.
                        </div>
                        <a asp-controller="Privacy" asp-action="RequestDeletion" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash3"></i> Account verwijderingsaanvraag indienen
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- ==========================================
             KAART 3: Toestemmingsgeschiedenis
        =========================================== -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history"></i> Mijn Toestemmingsgeschiedenis
                    </h5>
                    <span class="badge bg-light text-dark">@auditLogs.Count() vermeldingen</span>
                </div>
                <div class="card-body">
                    @if (!auditLogs.Any())
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-info-circle"></i> Nog geen toestemmingsactiviteit geregistreerd.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Datum</th>
                                        <th>Gebeurtenis</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in auditLogs.Take(10))
                                    {
                                        <tr>
                                            <td>
                                                <small class="text-muted">
                                                    @log.Timestamp.ToString("dd-MM-yyyy HH:mm")
                                                </small>
                                            </td>
                                            <td>
                                                @switch (log.EventType)
                                                {
                                                    case "ConsentGiven":
                                                        <span class="badge bg-success">
                                                            <i class="bi bi-check-circle"></i> Toestemming gegeven
                                                        </span>
                                                        break;
                                                    case "ConsentWithdrawn":
                                                        <span class="badge bg-warning text-dark">
                                                            <i class="bi bi-dash-circle"></i> Toestemming ingetrokken
                                                        </span>
                                                        break;
                                                    case "DeletionRequested":
                                                        <span class="badge bg-danger">
                                                            <i class="bi bi-trash"></i> Verwijdering aangevraagd
                                                        </span>
                                                        break;
                                                    case "DataExported":
                                                        <span class="badge bg-info">
                                                            <i class="bi bi-download"></i> Gegevens geëxporteerd
                                                        </span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@log.EventType</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    @log.ConsentType
                                                </span>
                                            </td>
                                            <td>
                                                @if (log.Granted)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-secondary"></i>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (auditLogs.Count() > 10)
                        {
                            <p class="small text-muted mt-2 mb-0">
                                <i class="bi bi-info-circle"></i>
                                Toont de 10 meest recente vermeldingen van in totaal @auditLogs.Count().
                            </p>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts na 5 seconden
        setTimeout(() => {
            document.querySelectorAll('.alert-dismissible').forEach(el => el.remove());
        }, 5000);
    </script>
}