@model ApplicationUser
@using Marketio_Web
@using Marketio_Web.Models
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = "Request Account Deletion";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill"></i> Delete Account
                    </h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <strong>⚠️ Warning:</strong>
                        <p class="mb-0 mt-2">
                            This action will permanently delete your account and all associated data.
                            This includes orders, preferences, and personal information.
                            This action cannot be undone.
                        </p>
                    </div>

                    <div class="mb-4">
                        <p><strong>Account Email:</strong> @Model.Email</p>
                        <p><strong>Name:</strong> @Model.FullName</p>
                    </div>

                    <form method="post" asp-action="ConfirmDeletion">
                        <div class="mb-3">
                            <label for="password" class="form-label">
                                Confirm Password <span class="text-danger">*</span>
                            </label>
                            <input type="password"
                                   id="password"
                                   name="password"
                                   class="form-control"
                                   required
                                   placeholder="Enter your password to confirm" />
                            <small class="text-muted">
                                For security, please enter your password to confirm deletion.
                            </small>
                        </div>

                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>Data Deletion (GDPR Right to be Forgotten):</strong>
                            <ul class="mb-0 mt-2">
                                <li>Your personal data will be deleted within 30 days</li>
                                <li>Order history will be anonymized for accounting purposes</li>
                                <li>You can request a data export before deletion</li>
                            </ul>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger flex-grow-1">
                                <i class="bi bi-trash-fill"></i> Delete My Account
                            </button>
                            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>