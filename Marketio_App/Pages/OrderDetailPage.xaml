<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Marketio_App.Pages.OrderDetailPage"
             Title="Bestellingdetails"
             BackgroundColor="#1E1E1E">

    <Grid RowDefinitions="*, Auto" RowSpacing="0" Padding="0">
        <!-- Loading State -->
        <VerticalStackLayout 
            Grid.Row="0"
            IsVisible="{Binding IsLoading}"
            Padding="20"
            Spacing="10"
            VerticalOptions="Center"
            HorizontalOptions="Center">
            <ActivityIndicator 
                IsRunning="True" 
                IsVisible="{Binding IsLoading}"
                Scale="1.5"
                Color="#FFFFFF" />
            <Label 
                Text="Bestelling wordt geladen..." 
                FontSize="14"
                TextColor="#FFFFFF"
                HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Error State -->
        <VerticalStackLayout 
            Grid.Row="0"
            IsVisible="{Binding HasOrder, Converter={StaticResource IsNotTrueConverter}}"
            Padding="20"
            Spacing="10"
            VerticalOptions="Center"
            HorizontalOptions="FillAndExpand">
            <Label 
                Text="⚠️ Fout"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="#FF6B6B" />
            <Label 
                Text="{Binding ErrorMessage}"
                FontSize="14"
                TextColor="#FFFFFF"
                LineBreakMode="WordWrap" />
            <Button 
                Text="Terug"
                Command="{Binding GoBackCommand}"
                Background="#007AFF"
                TextColor="White"
                CornerRadius="8" />
        </VerticalStackLayout>

        <!-- Content State -->
        <ScrollView 
            Grid.Row="0"
            IsVisible="{Binding HasOrder}">
            <VerticalStackLayout Padding="20" Spacing="15">
                <!-- Order Header -->
                <Frame 
                    Padding="15"
                    CornerRadius="10"
                    Background="#2D2D2D"
                    BorderColor="#404040">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label 
                                    Text="{Binding Order.OrderNumber, StringFormat='Bestelling {0}'}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="#FFFFFF" />
                                <Label 
                                    Text="{Binding Order.OrderDate, StringFormat='Datum: {0:dd MMMM yyyy HH:mm}'}"
                                    FontSize="12"
                                    TextColor="#B0B0B0" />
                            </VerticalStackLayout>
                            <Frame 
                                Grid.Column="1"
                                Padding="8"
                                CornerRadius="4"
                                Background="{Binding Order.Status, Converter={StaticResource StatusToColorConverter}}"
                                BorderColor="Transparent"
                                HasShadow="False">
                                <Label 
                                    Text="{Binding Order.StatusName}"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    VerticalTextAlignment="Center"
                                    HorizontalTextAlignment="Center" />
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Order Summary -->
                <Frame 
                    Padding="15"
                    CornerRadius="10"
                    Background="#2D2D2D"
                    BorderColor="#404040">
                    <VerticalStackLayout Spacing="10">
                        <Label 
                            Text="Bestelgegevens"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF" />

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Label 
                                Grid.Column="0" 
                                Text="Betalingsmethode:" 
                                FontAttributes="Bold"
                                TextColor="#E0E0E0" />
                            <Label 
                                Grid.Column="1" 
                                Text="{Binding Order.PaymentMethodName}" 
                                TextColor="#B0B0B0" />
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Label 
                                Grid.Column="0" 
                                Text="Aantal items:" 
                                FontAttributes="Bold"
                                TextColor="#E0E0E0" />
                            <Label 
                                Grid.Column="1" 
                                Text="{Binding Order.OrderItems.Count}" 
                                TextColor="#B0B0B0" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Order Items -->
                <Frame 
                    Padding="15"
                    CornerRadius="10"
                    Background="#2D2D2D"
                    BorderColor="#404040">
                    <VerticalStackLayout Spacing="10">
                        <Label 
                            Text="Bestelde Producten"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF" />

                        <CollectionView 
                            ItemsSource="{Binding Order.OrderItems}"
                            SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame 
                                        Padding="12"
                                        CornerRadius="8"
                                        Background="#383838"
                                        BorderColor="#505050"
                                        Margin="0,5">
                                        <Grid ColumnDefinitions="*, 60, 80" ColumnSpacing="10">
                                            <!-- Product Name -->
                                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                <Label 
                                                    Text="{Binding ProductName}"
                                                    FontSize="13"
                                                    FontAttributes="Bold"
                                                    TextColor="#FFFFFF" />
                                                <Label 
                                                    Text="{Binding UnitPrice, StringFormat='€{0:N2} per stuk'}"
                                                    FontSize="11"
                                                    TextColor="#B0B0B0" />
                                            </VerticalStackLayout>

                                            <!-- Quantity -->
                                            <Label 
                                                Grid.Column="1"
                                                Text="{Binding Quantity, StringFormat='x{0}'}"
                                                FontSize="12"
                                                TextColor="#E0E0E0"
                                                VerticalTextAlignment="Center"
                                                HorizontalTextAlignment="Center" />

                                            <!-- Total -->
                                            <Label 
                                                Grid.Column="2"
                                                Text="{Binding TotalPrice, StringFormat='€{0:N2}'}"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                TextColor="#FFFFFF"
                                                VerticalTextAlignment="Center"
                                                HorizontalTextAlignment="End" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Shipping Address -->
                <Frame 
                    Padding="15"
                    CornerRadius="10"
                    Background="#2D2D2D"
                    BorderColor="#404040">
                    <VerticalStackLayout Spacing="10">
                        <Label 
                            Text="📦 Verzendadres"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF" />
                        <Label 
                            Text="{Binding Order.ShippingAddress}"
                            FontSize="12"
                            TextColor="#E0E0E0"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Order Total -->
                <Frame 
                    Padding="15"
                    CornerRadius="10"
                    Background="#1B5E20"
                    BorderColor="#2E7D32">
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                        <Label 
                            Grid.Column="0"
                            Text="Totaalbedrag"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF"
                            VerticalTextAlignment="Center" />
                        <Label 
                            Grid.Column="1"
                            Text="{Binding Order.TotalAmount, StringFormat='€{0:N2}'}"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF"
                            VerticalTextAlignment="Center"
                            HorizontalTextAlignment="End" />
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Actions -->
        <VerticalStackLayout 
            Grid.Row="1"
            Padding="20"
            Spacing="10"
            BackgroundColor="#1E1E1E">
            <Button 
                Text="🔄 Vernieuwen"
                Command="{Binding RefreshOrderCommand}"
                Background="#007AFF"
                TextColor="White"
                CornerRadius="8" />
            <Button 
                Text="← Terug naar bestellingen"
                Command="{Binding GoBackCommand}"
                Background="Transparent"
                TextColor="#007AFF"
                BorderColor="#007AFF"
                BorderWidth="1"
                CornerRadius="8" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>