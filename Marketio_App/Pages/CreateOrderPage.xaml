<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Marketio_App.Pages.CreateOrderPage"
             Title="Nieuwe Bestelling">

    <ContentPage.Resources>
        <Color x:Key="LightBackgroundColor">#F5F5F5</Color>
        <Color x:Key="DarkBackgroundColor">#1F1F1F</Color>
        <Color x:Key="LightTextColor">#000000</Color>
        <Color x:Key="DarkTextColor">#FFFFFF</Color>
        <Color x:Key="LightSecondaryText">#666666</Color>
        <Color x:Key="DarkSecondaryText">#CCCCCC</Color>
        <Color x:Key="LightFrameBackground">#F0F0F0</Color>
        <Color x:Key="DarkFrameBackground">#3A3A3A</Color>
        <Color x:Key="SuccessGreen">#34C759</Color>
        <Color x:Key="ButtonBlue">#007AFF</Color>
        <Color x:Key="DangerRed">#FF3B30</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" BackgroundColor="{AppThemeBinding Light={StaticResource LightBackgroundColor}, Dark={StaticResource DarkBackgroundColor}}">

        <!-- Header -->
        <VerticalStackLayout 
            Padding="16" 
            Spacing="8"
            BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}">
            <Label 
                Text="Bestelling Plaatsen"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Loading Indicator -->
                <ActivityIndicator 
                    IsRunning="{Binding IsLoading}"
                    IsVisible="{Binding IsLoading}"
                    Color="{StaticResource ButtonBlue}" />

                <!-- Error Message -->
                <Frame 
                    BorderColor="{StaticResource DangerRed}"
                    CornerRadius="8"
                    Padding="12"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                    HasShadow="True">
                    <Label 
                        Text="{Binding ErrorMessage}"
                        TextColor="White"
                        BackgroundColor="{StaticResource DangerRed}"
                        FontSize="12" />
                </Frame>

                <!-- Empty Cart Message -->
                <Frame 
                    IsVisible="{Binding IsCartEmpty}"
                    CornerRadius="8"
                    Padding="16"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
                    HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label 
                            Text="Winkelwagen is leeg"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}"
                            HorizontalOptions="Center" />
                        <Label 
                            Text="Voeg producten toe voordat u een bestelling plaatst"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Cart Items -->
                <Frame 
                    IsVisible="{Binding IsCartEmpty, Converter={StaticResource IsNotTrueConverter}}"
                    CornerRadius="8"
                    Padding="12"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
                    HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label 
                            Text="Winkelwagen"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />

                        <CollectionView ItemsSource="{Binding CartItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Padding="8" Spacing="4" Margin="0,0,0,8">
                                        <StackLayout Orientation="Horizontal" Spacing="8">
                                            <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                                <Label 
                                                    Text="{Binding ProductName}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                                                <StackLayout Orientation="Horizontal" Spacing="8">
                                                    <Label 
                                                        Text="{Binding Quantity, StringFormat='{0}x'}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}" />
                                                    <Label 
                                                        Text="{Binding UnitPrice, StringFormat='€{0:F2}'}"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}" />
                                                </StackLayout>
                                            </VerticalStackLayout>
                                            <Label 
                                                Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource SuccessGreen}"
                                                VerticalOptions="Center" />
                                        </StackLayout>
                                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#DDDDDD, Dark=#404040}" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Cart Total -->
                        <StackLayout Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                            <Label 
                                Text="Subtotaal:"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}"
                                HorizontalOptions="FillAndExpand" />
                            <Label 
                                Text="{Binding CartTotal, StringFormat='€{0:F2}'}"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="{StaticResource SuccessGreen}" />
                        </StackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Shipping Address -->
                <Frame 
                    IsVisible="{Binding IsCartEmpty, Converter={StaticResource IsNotTrueConverter}}"
                    CornerRadius="8"
                    Padding="12"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
                    HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label 
                            Text="Verzendadres"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                        <Editor 
                            Text="{Binding ShippingAddress}"
                            Placeholder="Straat, huisnummer&#10;Postcode, plaats"
                            HeightRequest="100"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Billing Address -->
                <Frame 
                    IsVisible="{Binding IsCartEmpty, Converter={StaticResource IsNotTrueConverter}}"
                    CornerRadius="8"
                    Padding="12"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
                    HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <CheckBox 
                            IsChecked="{Binding SameAsShipping}"
                            Color="{StaticResource ButtonBlue}" />
                        <Label 
                            Text="Factuuradres hetzelfde als verzendadres"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}"
                            Margin="-8,0,0,0" />

                        <Frame 
                            IsVisible="{Binding SameAsShipping, Converter={StaticResource IsNotTrueConverter}}"
                            CornerRadius="4"
                            Padding="8"
                            BorderColor="Transparent"
                            BackgroundColor="Transparent"
                            HasShadow="False">
                            <VerticalStackLayout Spacing="8">
                                <Label 
                                    Text="Factuuradres"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                                <Editor 
                                    Text="{Binding BillingAddress}"
                                    Placeholder="Straat, huisnummer&#10;Postcode, plaats"
                                    HeightRequest="100"
                                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}"
                                    TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Action Buttons -->
                <VerticalStackLayout 
                    IsVisible="{Binding IsCartEmpty, Converter={StaticResource IsNotTrueConverter}}"
                    Spacing="8">
                    <Button 
                        Text="Bestelling Plaatsen"
                        Command="{Binding PlaceOrderCommand}"
                        BackgroundColor="{StaticResource ButtonBlue}"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        Padding="16" />
                    <Button 
                        Text="Terug naar winkelwagen"
                        Command="{Binding GoBackCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource ButtonBlue}"
                        FontSize="14"
                        CornerRadius="8" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>