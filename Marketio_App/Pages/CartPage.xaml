<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Marketio_App.Pages.CartPage"
             Title="Winkelwagen">

    <ContentPage.Resources>
        <Color x:Key="LightBackgroundColor">#F5F5F5</Color>
        <Color x:Key="DarkBackgroundColor">#1F1F1F</Color>
        <Color x:Key="LightTextColor">#000000</Color>
        <Color x:Key="DarkTextColor">#FFFFFF</Color>
        <Color x:Key="LightSecondaryText">#666666</Color>
        <Color x:Key="DarkSecondaryText">#CCCCCC</Color>
        <Color x:Key="LightFrameBackground">#F0F0F0</Color>
        <Color x:Key="DarkFrameBackground">#3A3A3A</Color>
        <Color x:Key="SuccessGreen">#34C759</Color>
        <Color x:Key="ButtonBlue">#007AFF</Color>
        <Color x:Key="DangerRed">#FF3B30</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" BackgroundColor="{AppThemeBinding Light={StaticResource LightBackgroundColor}, Dark={StaticResource DarkBackgroundColor}}">

        <!-- Header -->
        <VerticalStackLayout 
            Padding="16" 
            Spacing="8"
            BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}">
            <Label 
                Text="Winkelwagen"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Empty Cart Message -->
                <Frame 
                    IsVisible="{Binding IsCartEmpty}"
                    CornerRadius="8"
                    Padding="32"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
                    HasShadow="True"
                    VerticalOptions="CenterAndExpand">
                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                        <Label 
                            Text="Winkelwagen is leeg"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}"
                            HorizontalOptions="Center" />
                        <Label 
                            Text="Voeg producten toe om te beginnen"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}"
                            HorizontalOptions="Center" />
                        <Button 
                            Text="Terug naar producten"
                            Command="{Binding GoToProductsCommand}"
                            BackgroundColor="{StaticResource ButtonBlue}"
                            TextColor="White"
                            FontSize="14"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,16,0,0" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Cart Items -->
                <Frame 
                    IsVisible="{Binding IsCartEmpty, Converter={StaticResource IsNotTrueConverter}}"
                    CornerRadius="8"
                    Padding="12"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
                    HasShadow="True">
                    <CollectionView ItemsSource="{Binding CartItems}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Padding="8" Spacing="8" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="12">
                                        <!-- Product Image -->
                                        <Frame 
                                            Grid.Column="0"
                                            CornerRadius="6"
                                            Padding="0"
                                            BorderColor="Transparent"
                                            WidthRequest="80"
                                            HeightRequest="80"
                                            HasShadow="False">
                                            <Image 
                                                Source="{Binding ImageUrl}"
                                                Aspect="AspectFill" />
                                        </Frame>

                                        <!-- Product Info -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                            <Label 
                                                Text="{Binding ProductName}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                                            <Label 
                                                Text="{Binding UnitPrice, StringFormat='€{0:F2}/st'}"
                                                FontSize="12"
                                                TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}" />

                                            <!-- Quantity Controls -->
                                            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                                                <Button 
                                                    Text="-"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DecreaseQuantityCommand}"
                                                    CommandParameter="{Binding ProductId}"
                                                    BackgroundColor="{StaticResource ButtonBlue}"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    CornerRadius="4"
                                                    WidthRequest="32"
                                                    HeightRequest="32"
                                                    Padding="0" />
                                                <Label 
                                                    Text="{Binding Quantity}"
                                                    FontSize="12"
                                                    TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}"
                                                    VerticalOptions="Center"
                                                    WidthRequest="30"
                                                    HorizontalTextAlignment="Center" />
                                                <Button 
                                                    Text="+"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IncreaseQuantityCommand}"
                                                    CommandParameter="{Binding ProductId}"
                                                    BackgroundColor="{StaticResource SuccessGreen}"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    CornerRadius="4"
                                                    WidthRequest="32"
                                                    HeightRequest="32"
                                                    Padding="0" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Total Price & Remove -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center" HorizontalOptions="End">
                                            <Label 
                                                Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="{StaticResource SuccessGreen}"
                                                HorizontalOptions="End" />
                                            <Button 
                                                Text="✕"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveItemCommand}"
                                                CommandParameter="{Binding ProductId}"
                                                BackgroundColor="{StaticResource DangerRed}"
                                                TextColor="White"
                                                FontSize="12"
                                                CornerRadius="4"
                                                WidthRequest="32"
                                                HeightRequest="32"
                                                Padding="0" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#DDDDDD, Dark=#404040}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer with Total and Checkout Button -->
        <Frame 
            Grid.Row="2"
            IsVisible="{Binding IsCartEmpty, Converter={StaticResource IsNotTrueConverter}}"
            CornerRadius="12"
            Padding="16"
            Margin="12,0,12,12"
            BorderColor="Transparent"
            BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
            HasShadow="True">
            <VerticalStackLayout Spacing="12">
                <!-- Subtotal -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <Label 
                        Grid.Column="0"
                        Text="Subtotaal:"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                    <Label 
                        Grid.Column="1"
                        Text="{Binding CartTotal, StringFormat='€{0:F2}'}"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="{StaticResource SuccessGreen}" />
                </Grid>

                <!-- Checkout Button -->
                <Button 
                    Text="Naar afrekenen"
                    Command="{Binding GoToCheckoutCommand}"
                    BackgroundColor="{StaticResource ButtonBlue}"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="16" />

                <!-- Continue Shopping Button -->
                <Button 
                    Text="Doorgaan met winkelen"
                    Command="{Binding GoToProductsCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource ButtonBlue}"
                    FontSize="14"
                    CornerRadius="8" />
            </VerticalStackLayout>
        </Frame>

    </Grid>

</ContentPage>