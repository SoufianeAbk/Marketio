<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Marketio_App.Pages.RegisterPage"
             Title="Registreren"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header -->
            <Label 
                Text="Maak een account aan"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                Margin="0,20,0,10" />

            <Label 
                Text="Vul uw gegevens in om een nieuw account te maken"
                FontSize="14"
                HorizontalTextAlignment="Center"
                TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}"
                Margin="0,0,0,20" />

            <!-- Error Message -->
            <Frame 
                BorderColor="Red"
                CornerRadius="8"
                Padding="12"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                HasShadow="True">
                <Label 
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    BackgroundColor="#FF6B6B"
                    FontSize="12" />
            </Frame>

            <!-- Email Input -->
            <VerticalStackLayout Spacing="8">
                <Label 
                    Text="E-mailadres *"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Entry 
                    Placeholder="uw@email.com"
                    Text="{Binding Email}"
                    Keyboard="Email"
                    FontSize="14"
                    PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
            </VerticalStackLayout>

            <!-- First Name Input -->
            <VerticalStackLayout Spacing="8">
                <Label 
                    Text="Voornaam *"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Entry 
                    Placeholder="Voornaam"
                    Text="{Binding FirstName}"
                    FontSize="14"
                    PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
            </VerticalStackLayout>

            <!-- Last Name Input -->
            <VerticalStackLayout Spacing="8">
                <Label 
                    Text="Achternaam *"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Entry 
                    Placeholder="Achternaam"
                    Text="{Binding LastName}"
                    FontSize="14"
                    PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
            </VerticalStackLayout>

            <!-- Address Input -->
            <VerticalStackLayout Spacing="8">
                <Label 
                    Text="Adres"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Entry 
                    Placeholder="Straatnaam en huisnummer"
                    Text="{Binding Address}"
                    FontSize="14"
                    PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
            </VerticalStackLayout>

            <!-- Password Input -->
            <VerticalStackLayout Spacing="8">
                <Label 
                    Text="Wachtwoord *"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Entry 
                    Placeholder="Minimaal 6 tekens"
                    Text="{Binding Password}"
                    IsPassword="True"
                    FontSize="14"
                    PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
            </VerticalStackLayout>

            <!-- Confirm Password Input -->
            <VerticalStackLayout Spacing="8">
                <Label 
                    Text="Bevestig wachtwoord *"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Entry 
                    Placeholder="Herhaal uw wachtwoord"
                    Text="{Binding ConfirmPassword}"
                    IsPassword="True"
                    FontSize="14"
                    PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
            </VerticalStackLayout>

            <!-- Accept Terms Checkbox -->
            <StackLayout Orientation="Horizontal" Spacing="12" Margin="0,8">
                <CheckBox 
                    IsChecked="{Binding AcceptTerms}"
                    VerticalOptions="Center" />
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label 
                        Text="Ik accepteer de "
                        FontSize="14"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Ik accepteer de " TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                                <Span Text="voorwaarden" TextColor="#007AFF" FontAttributes="Bold">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenTermsCommand}" />
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </StackLayout>

            <!-- Accept Privacy Policy Checkbox -->
            <StackLayout Orientation="Horizontal" Spacing="12" Margin="0,8">
                <CheckBox 
                    IsChecked="{Binding AcceptPrivacyPolicy}"
                    VerticalOptions="Center" />
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label 
                        Text="Privacy Policy">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Ik accepteer het " TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                                <Span Text="privacybeleid" TextColor="#007AFF" FontAttributes="Bold">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenPrivacyPolicyCommand}" />
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </StackLayout>

            <!-- Marketing Opt-in (Optional) -->
            <StackLayout Orientation="Horizontal" Spacing="12" Margin="0,8">
                <CheckBox 
                    IsChecked="{Binding AcceptMarketing}"
                    VerticalOptions="Center" />
                <Label 
                    Text="Ik wil graag aanbiedingen en nieuwsberichten ontvangen"
                    VerticalOptions="Center"
                    FontSize="14"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}" />
            </StackLayout>

            <!-- GDPR Notice -->
            <Frame 
                BorderColor="#34C759"
                CornerRadius="8"
                Padding="12"
                HasShadow="False"
                BackgroundColor="{AppThemeBinding Light=#F0F9F4, Dark=#1a3a2a}">
                <Label 
                    Text="Uw gegevens worden veilig behandeld in overeenstemming met de AVG (GDPR). U kunt uw account op elk moment verwijderen."
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#1a3a2a, Dark=#90EE90}"
                    LineBreakMode="WordWrap" />
            </Frame>

            <!-- Register Button -->
            <Button 
                Text="Account aanmaken"
                Command="{Binding RegisterCommand}"
                BackgroundColor="#34C759"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                CornerRadius="8"
                Padding="16"
                IsEnabled="{Binding IsLoading, Converter={StaticResource IsNotTrueConverter}}"
                Margin="0,16" />

            <!-- Loading Indicator -->
            <ActivityIndicator 
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#34C759"
                HorizontalOptions="Center"
                Margin="0,16" />

            <!-- Login Link -->
            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="4" Margin="0,20">
                <Label 
                    Text="Heeft u al een account?"
                    FontSize="14"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}" />
                <Button 
                    Text="Meld u aan"
                    Command="{Binding NavigateToLoginCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#007AFF"
                    FontSize="14"
                    FontAttributes="Bold"
                    Padding="0" />
            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>