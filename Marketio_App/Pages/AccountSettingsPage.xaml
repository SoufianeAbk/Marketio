<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Marketio_App.Pages.AccountSettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Accountinstellingen"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- Header -->
        <StackLayout
            Grid.Row="0"
            Padding="16"
            Spacing="8"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}">

            <Label
                FontAttributes="Bold"
                FontSize="20"
                Text="Mijn Account"
                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
            <Label
                FontSize="12"
                Opacity="0.7"
                Text="Beheer uw persoonlijke gegevens en privacy-instellingen"
                TextColor="{AppThemeBinding Light=#666666, Dark=#BBBBBB}" />
        </StackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <StackLayout Padding="16" Spacing="16">

                <!-- Loading State -->
                <StackLayout
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsLoading}"
                    VerticalOptions="Center">
                    <ActivityIndicator
                        Color="#0078D4"
                        IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}" />
                    <Label
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        Text="Laden..."
                        TextColor="{AppThemeBinding Light=#666666, Dark=#BBBBBB}" />
                </StackLayout>

                <!-- Messages -->
                <StackLayout IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}" Spacing="8">
                    <Frame BackgroundColor="#FFE6E6" BorderColor="#CC0000" CornerRadius="8" Padding="12">
                        <Label
                            FontSize="12"
                            Text="{Binding ErrorMessage}"
                            TextColor="#CC0000" />
                    </Frame>
                </StackLayout>

                <StackLayout IsVisible="{Binding SuccessMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}" Spacing="8">
                    <Frame BackgroundColor="#E6FFE6" BorderColor="#00AA00" CornerRadius="8" Padding="12">
                        <Label
                            FontSize="12"
                            Text="{Binding SuccessMessage}"
                            TextColor="#00AA00" />
                    </Frame>
                </StackLayout>

                <!-- Profiel Card -->
                <Frame
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                    BorderColor="#D0D0D0"
                    CornerRadius="12"
                    HasShadow="True"
                    Padding="16">

                    <StackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Profielgegevens"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="12">
                            <!-- Email (read-only) -->
                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="Email"
                                TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                FontSize="14"
                                Text="{Binding Email}"
                                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                            <!-- First Name (read-only) -->
                            <Label
                                Grid.Row="2"
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="Voornaam"
                                TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label
                                Grid.Row="3"
                                Grid.Column="0"
                                FontSize="14"
                                Text="{Binding FirstName}"
                                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                            <!-- Last Name (read-only) -->
                            <Label
                                Grid.Row="2"
                                Grid.Column="1"
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="Achternaam"
                                TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label
                                Grid.Row="3"
                                Grid.Column="1"
                                FontSize="14"
                                Text="{Binding LastName}"
                                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        </Grid>

                        <Button
                            Command="{Binding LoadProfileCommand}"
                            FontSize="13"
                            Text="Vernieuwen"
                            TextColor="#FFFFFF"
                            BackgroundColor="#0078D4"
                            Padding="12" />
                    </StackLayout>
                </Frame>

                <!-- Privacy & Consent Card -->
                <Frame
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                    BorderColor="#D0D0D0"
                    CornerRadius="12"
                    HasShadow="True"
                    Padding="16">

                    <StackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Privacy-instellingen"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                        <StackLayout Spacing="8">
                            <CheckBox
                                Color="#0078D4"
                                IsChecked="{Binding MarketingOptIn}"
                                VerticalOptions="Center" />
                            <Label
                                FontSize="14"
                                Text="Ik wil graag aanbiedingen en updates ontvangen"
                                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        </StackLayout>

                        <Button
                            Command="{Binding UpdateConsentCommand}"
                            FontSize="13"
                            Text="Toestemming opslaan"
                            TextColor="#FFFFFF"
                            BackgroundColor="#0078D4"
                            Padding="12" />
                    </StackLayout>
                </Frame>

                <!-- GDPR Rights Card -->
                <Frame
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                    BorderColor="#D0D0D0"
                    CornerRadius="12"
                    HasShadow="True"
                    Padding="16">

                    <StackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="GDPR-rechten"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        <Label
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            Text="U heeft het recht op inzage, correctie en verwijdering van uw gegevens."
                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                        <!-- Export Data -->
                        <Button
                            Command="{Binding ExportDataCommand}"
                            FontSize="13"
                            Text="📥 Mijn gegevens exporteren"
                            TextColor="#FFFFFF"
                            BackgroundColor="#17A2B8"
                            Padding="12" />

                        <!-- Request Deletion -->
                        <Button
                            Command="{Binding ShowDeletionConfirmationCommand}"
                            FontSize="13"
                            Text="🗑️ Account verwijderen"
                            TextColor="#FFFFFF"
                            BackgroundColor="#DC3545"
                            Padding="12"
                            IsVisible="{Binding IsDeletionRequested, Converter={StaticResource IsNotTrueConverter}}" />

                        <Label
                            FontSize="12"
                            Padding="8"
                            Text="⏳ Verwijderingaanvraag in behandeling (verwijdert binnen 30 dagen)"
                            TextColor="#FFC107"
                            BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#3D3D00}"
                            IsVisible="{Binding IsDeletionRequested}" />
                    </StackLayout>
                </Frame>

                <!-- Audit Trail Card -->
                <Frame
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                    BorderColor="#D0D0D0"
                    CornerRadius="12"
                    HasShadow="True"
                    Padding="16"
                    IsVisible="{Binding AuditLogs, Converter={StaticResource IsNotNullConverter}}">

                    <StackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Audittrail"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                        <Label
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            Text="Historie van toestemming en gegevensbewerkingen"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                        <CollectionView ItemsSource="{Binding AuditLogs}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <StackLayout Padding="8" Spacing="4">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            Text="{Binding EventType}"
                                            TextColor="{AppThemeBinding Light=#0078D4, Dark=#64B5F6}" />
                                        <Label
                                            FontSize="11"
                                            Text="{Binding Timestamp, StringFormat='{0:dd-MM-yyyy HH:mm:ss}'}"
                                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                                    </StackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                </Frame>

                <!-- Logout Button -->
                <Button
                    Command="{Binding LogoutCommand}"
                    FontSize="13"
                    Text="Uitloggen"
                    TextColor="#FFFFFF"
                    BackgroundColor="#6C757D"
                    Padding="12" />
            </StackLayout>
        </ScrollView>

        <!-- Deletion Confirmation Dialog (Overlay) -->
        <StackLayout
            Grid.Row="0"
            Grid.RowSpan="2"
            BackgroundColor="#00000080"
            IsVisible="{Binding ShowDeletionDialog}"
            VerticalOptions="Center"
            HorizontalOptions="Center">

            <Frame
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                BorderColor="#D0D0D0"
                CornerRadius="12"
                HasShadow="True"
                Margin="24"
                Padding="20"
                WidthRequest="300"
                HorizontalOptions="Center">

                <StackLayout Spacing="16">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Account verwijderen"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                    <Label
                        FontSize="13"
                        LineBreakMode="WordWrap"
                        Text="Dit kan niet ongedaan gemaakt worden. Uw account en alle persoonlijke gegevens worden permanent verwijderd."
                        TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                    <Entry
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3D3D3D}"
                        IsPassword="True"
                        Placeholder="Voer uw wachtwoord in"
                        Text="{Binding DeletionPassword}"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button
                            Grid.Column="0"
                            Command="{Binding CancelDeletionCommand}"
                            FontSize="13"
                            Text="Annuleren"
                            TextColor="#0078D4"
                            BackgroundColor="Transparent"
                            BorderColor="#0078D4"
                            BorderWidth="1"
                            Padding="12" />

                        <Button
                            Grid.Column="1"
                            Command="{Binding ConfirmDeletionCommand}"
                            FontSize="13"
                            Text="Verwijderen"
                            TextColor="#FFFFFF"
                            BackgroundColor="#DC3545"
                            Padding="12" />
                    </Grid>
                </StackLayout>
            </Frame>
        </StackLayout>
    </Grid>
</ContentPage>