<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Marketio_App.Pages.ProductsPage"
             Title="Producten"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">

    <Grid RowDefinitions="Auto,*" Padding="0" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">

        <!-- Header with Search and Filter -->
        <VerticalStackLayout 
            Grid.Row="0"
            Padding="16" 
            Spacing="12" 
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}">

            <Label 
                Text="Producten"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

            <!-- Search Bar -->
            <SearchBar 
                Placeholder="Zoeken naar producten..."
                Text="{Binding SearchQuery}"
                CancelButtonColor="#007AFF"
                PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" />

            <!-- Category Filter Picker -->
            <Picker 
                Title="Selecteer categorie"
                SelectedItem="{Binding SelectedCategory}"
                FontSize="14"
                TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#3A3A3A}" />

        </VerticalStackLayout>

        <!-- Loading Indicator (Above everything) -->
        <ActivityIndicator 
            Grid.Row="1"
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            Color="#007AFF"
            VerticalOptions="Center"
            HorizontalOptions="Center" />

        <!-- Error Message -->
        <Frame 
            Grid.Row="1"
            BorderColor="Red"
            CornerRadius="8"
            Padding="12"
            Margin="16"
            IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"
            HasShadow="True"
            VerticalOptions="Start">
            <Label 
                Text="{Binding ErrorMessage}"
                TextColor="White"
                BackgroundColor="#FF6B6B"
                FontSize="12" />
        </Frame>

        <!-- Products Grid or Empty State -->
        <RefreshView 
            Grid.Row="1"
            Command="{Binding RefreshProductsCommand}"
            IsRefreshing="{Binding IsRefreshing}"
            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
            VerticalOptions="Fill"
            HorizontalOptions="Fill">

            <CollectionView 
                x:Name="ProductsCollectionView"
                ItemsSource="{Binding Products}"
                SelectionMode="None"
                VerticalOptions="Fill"
                HorizontalOptions="Fill"
                Margin="12,8">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            CornerRadius="14"
                            Padding="12"
                            HasShadow="True"
                            BorderColor="Transparent"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}">

                            <Grid ColumnDefinitions="220,*" ColumnSpacing="14" MinimumHeightRequest="150">

                                <Frame 
                                    Grid.Column="0"
                                    CornerRadius="10"
                                    Padding="0"
                                    HasShadow="False"
                                    BorderColor="Transparent"
                                    WidthRequest="220"
                                    HeightRequest="130"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Center">
                                    <Image 
                                        Source="{Binding ImageUrl}"
                                        Aspect="AspectFill" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                    <Label 
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2" />

                                    <Label 
                                        Text="{Binding Description}"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="3" />

                                    <HorizontalStackLayout Spacing="6" Margin="0,6,0,0">
                                        <Label 
                                            Text="{Binding Price, StringFormat='€{0:F2}'}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="#34C759"
                                            VerticalOptions="Center" />
                                        <Label 
                                            Text="{Binding Stock, StringFormat='{0}x'}"
                                            FontSize="13"
                                            TextColor="{AppThemeBinding Light=#999999, Dark=#AAAAAA}"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectProductCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="16" Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label 
                            Text="Geen producten gevonden"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                            HorizontalOptions="Center" />
                        <Label 
                            Text="Probeer uw zoekopdracht aan te passen"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>

        </RefreshView>

    </Grid>

</ContentPage>