<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Marketio_App.Pages.ProductDetailPage"
             Title="Productdetails">

    <ContentPage.Resources>
        <Color x:Key="LightBackgroundColor">#F5F5F5</Color>
        <Color x:Key="DarkBackgroundColor">#1F1F1F</Color>
        <Color x:Key="LightTextColor">#000000</Color>
        <Color x:Key="DarkTextColor">#FFFFFF</Color>
        <Color x:Key="LightSecondaryText">#666666</Color>
        <Color x:Key="DarkSecondaryText">#CCCCCC</Color>
        <Color x:Key="LightFrameBackground">#F0F0F0</Color>
        <Color x:Key="DarkFrameBackground">#3A3A3A</Color>
        <Color x:Key="SuccessGreen">#34C759</Color>
        <Color x:Key="ButtonBlue">#007AFF</Color>
        <Color x:Key="OrangeButton">#FF9500</Color>
    </ContentPage.Resources>

    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource LightBackgroundColor}, Dark={StaticResource DarkBackgroundColor}}">
        <VerticalStackLayout Spacing="16" Padding="16">

            <!-- Loading Indicator -->
            <ActivityIndicator 
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="{StaticResource ButtonBlue}"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

            <!-- Error Message -->
            <Frame 
                BorderColor="Red"
                CornerRadius="8"
                Padding="12"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                HasShadow="True">
                <Label 
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    BackgroundColor="#FF6B6B"
                    FontSize="12" />
            </Frame>

            <!-- Product Image -->
            <Frame 
                CornerRadius="12"
                Padding="0"
                HasShadow="True"
                BorderColor="Transparent"
                IsVisible="{Binding Product, Converter={StaticResource IsNotNullConverter}}">
                <Image 
                    Source="{Binding Product.ImageUrl}"
                    Aspect="AspectFill"
                    HeightRequest="300" />
            </Frame>

            <!-- Product Details -->
            <StackLayout IsVisible="{Binding Product, Converter={StaticResource IsNotNullConverter}}" Spacing="12">

                <!-- Product Name -->
                <Label 
                    Text="{Binding Product.Name}"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />

                <!-- Price and Stock -->
                <StackLayout Orientation="Horizontal" Spacing="16">
                    <StackLayout Spacing="4">
                        <Label 
                            Text="Prijs"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}" />
                        <Label 
                            Text="{Binding Product.Price, StringFormat='€{0:F2}'}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource SuccessGreen}" />
                    </StackLayout>

                    <StackLayout Spacing="4">
                        <Label 
                            Text="Voorraad"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}" />
                        <Label 
                            Text="{Binding Product.Stock, StringFormat='{0} beschikbaar'}"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{Binding Product.Stock, Converter={StaticResource StockToColorConverter}}" />
                    </StackLayout>
                </StackLayout>

                <!-- Description -->
                <VerticalStackLayout Spacing="8">
                    <Label 
                        Text="Beschrijving"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                    <Label 
                        Text="{Binding Product.Description}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <!-- Category -->
                <StackLayout Orientation="Horizontal" Spacing="8">
                    <Label 
                        Text="Categorie:"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />
                    <Label 
                        Text="{Binding Product.Category}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkSecondaryText}}" />
                </StackLayout>

                <!-- Quantity Selector -->
                <VerticalStackLayout Spacing="8" Margin="0,16">
                    <Label 
                        Text="Hoeveelheid"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}" />

                    <StackLayout Orientation="Horizontal" Spacing="12" HorizontalOptions="Start">
                        <Button 
                            Text="-"
                            Command="{Binding DecreaseQuantityCommand}"
                            BackgroundColor="{StaticResource OrangeButton}"
                            TextColor="White"
                            FontSize="18"
                            CornerRadius="8"
                            WidthRequest="50"
                            HeightRequest="50"
                            Padding="0" />

                        <Entry 
                            Text="{Binding Quantity}"
                            Keyboard="Numeric"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            WidthRequest="80"
                            IsReadOnly="True" />

                        <Button 
                            Text="+"
                            Command="{Binding IncreaseQuantityCommand}"
                            BackgroundColor="{StaticResource SuccessGreen}"
                            TextColor="White"
                            FontSize="18"
                            CornerRadius="8"
                            WidthRequest="50"
                            HeightRequest="50"
                            Padding="0" />
                    </StackLayout>
                </VerticalStackLayout>

                <!-- Total Price -->
                <Frame 
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightFrameBackground}, Dark={StaticResource DarkFrameBackground}}"
                    CornerRadius="8"
                    Padding="12"
                    BorderColor="Transparent">
                    <StackLayout Orientation="Horizontal" Spacing="16" HorizontalOptions="FillAndExpand">
                        <Label 
                            Text="Totaal:"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light={StaticResource LightTextColor}, Dark={StaticResource DarkTextColor}}"
                            VerticalOptions="Center" />
                        <Label 
                            Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource SuccessGreen}"
                            HorizontalOptions="End"
                            VerticalOptions="Center" />
                    </StackLayout>
                </Frame>

                <!-- Add to Cart Button -->
                <Button 
                    Text="In winkelwagen plaatsen"
                    Command="{Binding AddToCartCommand}"
                    BackgroundColor="{StaticResource ButtonBlue}"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,16" />

                <!-- Back Button -->
                <Button 
                    Text="Terug naar producten"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource ButtonBlue}"
                    FontSize="14"
                    CornerRadius="8" />

            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>