<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Marketio_App.Pages.ProductDetailPage"
             Title="Productdetails"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1F1F1F}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <!-- Loading Indicator -->
            <ActivityIndicator 
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#007AFF"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

            <!-- Error Message -->
            <Frame 
                BorderColor="Red"
                CornerRadius="8"
                Padding="12"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                HasShadow="True">
                <Label 
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    BackgroundColor="#FF6B6B"
                    FontSize="12" />
            </Frame>

            <!-- Product Image -->
            <Frame 
                CornerRadius="12"
                Padding="0"
                HasShadow="True"
                BorderColor="Transparent"
                IsVisible="{Binding Product, Converter={StaticResource IsNotNullConverter}}">
                <Image 
                    Source="product_placeholder.png"
                    Aspect="AspectFill"
                    HeightRequest="300" />
            </Frame>

            <!-- Product Details -->
            <StackLayout IsVisible="{Binding Product, Converter={StaticResource IsNotNullConverter}}" Spacing="12">

                <!-- Product Name -->
                <Label 
                    Text="{Binding Product.Name}"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                <!-- Price and Stock -->
                <StackLayout Orientation="Horizontal" Spacing="16">
                    <StackLayout Spacing="4">
                        <Label 
                            Text="Prijs"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}" />
                        <Label 
                            Text="{Binding Product.Price, StringFormat='€{0:F2}'}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#34C759" />
                    </StackLayout>

                    <StackLayout Spacing="4">
                        <Label 
                            Text="Voorraad"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}" />
                        <Label 
                            Text="{Binding Product.Stock, StringFormat='{0} beschikbaar'}"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{Binding Product.Stock, Converter={StaticResource StockToColorConverter}}" />
                    </StackLayout>
                </StackLayout>

                <!-- Description -->
                <VerticalStackLayout Spacing="8">
                    <Label 
                        Text="Beschrijving"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label 
                        Text="{Binding Product.Description}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <!-- Category -->
                <StackLayout Orientation="Horizontal" Spacing="8">
                    <Label 
                        Text="Categorie:"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label 
                        Text="{Binding Product.Category}"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light=#666666, Dark=#CCCCCC}" />
                </StackLayout>

                <!-- Quantity Selector -->
                <VerticalStackLayout Spacing="8" Margin="0,16">
                    <Label 
                        Text="Hoeveelheid"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />

                    <StackLayout Orientation="Horizontal" Spacing="12" HorizontalOptions="Start">
                        <Button 
                            Text="-"
                            Command="{Binding DecreaseQuantityCommand}"
                            BackgroundColor="#FF9500"
                            TextColor="White"
                            FontSize="18"
                            CornerRadius="8"
                            WidthRequest="50"
                            HeightRequest="50"
                            Padding="0" />

                        <Entry 
                            Text="{Binding Quantity}"
                            Keyboard="Numeric"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            WidthRequest="80"
                            IsReadOnly="True" />

                        <Button 
                            Text="+"
                            Command="{Binding IncreaseQuantityCommand}"
                            BackgroundColor="#34C759"
                            TextColor="White"
                            FontSize="18"
                            CornerRadius="8"
                            WidthRequest="50"
                            HeightRequest="50"
                            Padding="0" />
                    </StackLayout>
                </VerticalStackLayout>

                <!-- Total Price -->
                <Frame 
                    BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#3A3A3A}"
                    CornerRadius="8"
                    Padding="12"
                    BorderColor="Transparent">
                    <StackLayout Orientation="Horizontal" Spacing="16" HorizontalOptions="FillAndExpand">
                        <Label 
                            Text="Totaal:"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                            VerticalOptions="Center" />
                        <Label 
                            Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#34C759"
                            HorizontalOptions="End"
                            VerticalOptions="Center" />
                    </StackLayout>
                </Frame>

                <!-- Add to Cart Button -->
                <Button 
                    Text="In winkelwagen plaatsen"
                    Command="{Binding AddToCartCommand}"
                    BackgroundColor="#007AFF"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,16" />

                <!-- Back Button -->
                <Button 
                    Text="Terug naar producten"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#007AFF"
                    FontSize="14"
                    CornerRadius="8" />

            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>