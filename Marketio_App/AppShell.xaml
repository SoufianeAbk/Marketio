<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Marketio_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Marketio_App.Pages"
    Title="Marketio">

    <!-- Authentication Routes (accessible without tabbar) -->
    <ShellContent 
        Title="Login"
        ContentTemplate="{DataTemplate local:LoginPage}"
        Route="login" />

    <ShellContent 
        Title="Register"
        ContentTemplate="{DataTemplate local:RegisterPage}"
        Route="register" />

    <!-- Main App with TabBar (after authentication) -->
    <TabBar>
        <!-- Products Tab -->
        <ShellContent 
            Title="Producten"
            Icon="shop.png"
            ContentTemplate="{DataTemplate local:ProductsPage}"
            Route="producten" />

        <!-- Orders Tab -->
        <ShellContent 
            Title="Bestellingen"
            Icon="bag.png"
            ContentTemplate="{DataTemplate local:OrdersPage}"
            Route="orders" />

        <!-- Account Settings Tab -->
        <ShellContent 
            Title="Instellingen"
            Icon="settings.png"
            ContentTemplate="{DataTemplate local:AccountSettingsPage}"
            Route="account-settings" />
    </TabBar>

    <!-- Detail Routes (nested under producten for modal navigation) -->
    <ShellContent
        Title="Product Detail"
        ContentTemplate="{DataTemplate local:ProductDetailPage}"
        Route="product-detail" />

    <!-- Order Detail Route (nested under orders for modal navigation) -->
    <ShellContent
        Title="Order Detail"
        ContentTemplate="{DataTemplate local:OrderDetailPage}"
        Route="order-detail" />

    <!-- Create Order Route -->
    <ShellContent
        Title="Create Order"
        ContentTemplate="{DataTemplate local:CreateOrderPage}"
        Route="create-order" />

</Shell>